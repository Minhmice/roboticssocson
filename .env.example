# Canonical public origin (no trailing slash). Required for production SEO.
NEXT_PUBLIC_SITE_URL=https://roboticssocson.minhmice.com

# Analytics — leave empty to skip loading scripts
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=roboticssocson.minhmice.com

# Set to "true" to disable boot loader (every page load + route transitions)
# NEXT_PUBLIC_DISABLE_BOOT_LOADER=true

