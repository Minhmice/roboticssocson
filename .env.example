# Canonical public origin (no trailing slash). Required for production SEO.
NEXT_PUBLIC_SITE_URL=https://roboticssocson.minhmice.com

# PostHog — client capture + internal dashboard queries
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=/ingest
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
POSTHOG_PROJECT_ID=506211
POSTHOG_API_HOST=https://us.posthog.com
# Personal API key (phx_…) — required for /analytics HogQL summary
# Create at https://us.posthog.com/settings/user-api-keys (scope: query:read)
# Or run: node scripts/set-posthog-personal-key.mjs phx_your_key
POSTHOG_PERSONAL_API_KEY=

# Password-protected /analytics dashboard (server-only)
ANALYTICS_DASHBOARD_PASSWORD=
# Optional HMAC secret for session cookie (defaults to password-derived dev secret)
# ANALYTICS_AUTH_SECRET=

# Password-protected /course/arduino-mblock-deck (internal team presentations)
# Falls back to ANALYTICS_DASHBOARD_PASSWORD when unset
DECK_PRESENTATION_PASSWORD=
# DECK_AUTH_SECRET=

# Analytics — leave empty to skip loading scripts
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=roboticssocson.minhmice.com

# Set to "true" to disable boot loader (every page load + route transitions)
# NEXT_PUBLIC_DISABLE_BOOT_LOADER=true

# TODO(Sentry): install @sentry/nextjs then add:
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
